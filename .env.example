# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=loandb
POSTGRES_USER=loanuser
POSTGRES_PASSWORD=loanpass
DATABASE_URL=postgresql+asyncpg://loanuser:loanpass@localhost:5432/loandb

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=redispass
REDIS_URL=redis://:redispass@localhost:6379/0

# ── Ollama (Local LLM) ────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_FALLBACK_MODEL=llama3.1:latest
4
# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# ── Services ──────────────────────────────────────────────────
MOCK_HUB_URL=http://localhost:9000
BACKEND_URL=http://localhost:8080
KONG_PROXY_URL=http://localhost:8000
KONG_ADMIN_URL=http://localhost:8001

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# ── Email (MailHog locally) ───────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@loanagent.local
MAILHOG_UI=http://localhost:8025

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO